{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-check-20260413-2/types/**/*.ts",
    ".next-check-20260413-2/dev/types/**/*.ts",
    ".next-check-20260413-4/types/**/*.ts",
    ".next-check-20260413-4/dev/types/**/*.ts",
    ".next-check-20260413-5/types/**/*.ts",
    ".next-check-20260413-5/dev/types/**/*.ts",
    ".next-check-20260415-deposits/types/**/*.ts",
    ".next-check-20260415-deposits/dev/types/**/*.ts",
    ".next-check-20260415-liabilities/types/**/*.ts",
    ".next-check-20260415-liabilities/dev/types/**/*.ts",
    ".next-check-20260415-liabilities-2/types/**/*.ts",
    ".next-check-20260415-liabilities-2/dev/types/**/*.ts",
    ".next-check-upload/types/**/*.ts",
    ".next-check-upload/dev/types/**/*.ts",
    ".next-check-upload-2/types/**/*.ts",
    ".next-check-upload-2/dev/types/**/*.ts",
    ".next-check-upload-3/types/**/*.ts",
    ".next-check-upload-3/dev/types/**/*.ts",
    ".next-check-upload-4/types/**/*.ts",
    ".next-check-upload-4/dev/types/**/*.ts",
    ".next-check-upload-execute-msg/types/**/*.ts",
    ".next-check-upload-execute-msg/dev/types/**/*.ts",
    ".next-check-upload-account51/types/**/*.ts",
    ".next-check-upload-account51/dev/types/**/*.ts",
    ".next-check-upload-account50/types/**/*.ts",
    ".next-check-upload-account50/dev/types/**/*.ts",
    ".next-check-upload-account51-expenses/types/**/*.ts",
    ".next-check-upload-account51-expenses/dev/types/**/*.ts",
    ".next-check-upload-account55/types/**/*.ts",
    ".next-check-upload-account55/dev/types/**/*.ts",
    ".next-check-upload-account67/types/**/*.ts",
    ".next-check-upload-account67/dev/types/**/*.ts",
    ".next-check-upload-journal/types/**/*.ts",
    ".next-check-upload-journal/dev/types/**/*.ts",
    ".next-check-upload-account67-fix/types/**/*.ts",
    ".next-check-upload-account67-fix/dev/types/**/*.ts",
    ".next-check-upload-account67-202425-fix/types/**/*.ts",
    ".next-check-upload-account67-202425-fix/dev/types/**/*.ts"
  ],
  "exclude": [
    "**/_backups_*",
    "**/app__backup_*",
    "**/app_backup_*",
    "**/backups/**",
    "**/components__backup_*",
    "**/lib__backup_*",
    ".next",
    ".turbo",
    "_backups_*",
    "app__backup_*",
    "app_backup_*",
    "backups",
    "components__backup_*",
    "lib__backup_*",
    "node_modules"
  ]
}
